# Flask Configuration
FLASK_CONFIG=development
FLASK_DEBUG=True

# Security Keys
# Сгенерируй новые значения: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-too

# Logging
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,*

# PostgreSQL Database
DATABASE_URL=postgresql://postgres:postgres123@db:5432/hackathon_db

# Database Variables (для docker-compose)
DB_NAME=hackathon_db
DB_USER=postgres
DB_PASSWORD=postgres123
DB_HOST=db
DB_PORT=5432

# FILE UPLOADS
# Путь внутри контейнера для сохранения файлов
UPLOAD_FOLDER=/app/uploads

# Публичный URL для доступа к файлам (через Nginx)
UPLOADS_URL=/uploads

# Лимиты загрузки
MAX_CONTENT_LENGTH=16777216 # 16 MB (лимит Flask)
MAX_LOGO_SIZE=5242880 # 5 MB (бизнес-лимит)
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,webp